{
  "name": "action-azure-upload-blob",
  "version": "3.11.0",
  "private": false,
  "description": "GitHub Action that uploads files to an Azure Storage blob container.",
  "main": "lib/main.js",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com/"
  },
  "scripts": {
    "clean": "rimraf lib && npm ci",
    "build": "tsc",
    "rebuild": "npm run clean && npm run build",
    "format": "prettier --write **/*.ts",
    "lint": "eslint src/**/*.ts",
    "audit": "npm audit",
    "audit:prod": "npm audit --omit=dev",
    "package": "ncc build lib/main.js --source-map --license licenses.txt",
    "test": "jest --coverage",
    "update-browser-list": "npx update-browserslist-db@latest",
    "pre-commit": "npm run format && npm run lint && npm run rebuild && npm run package",
    "all": "npm ci && npm run format && npm run lint && npm run rebuild && npm run package && npm test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LanceMcCarthy/Action-AzureBlobUpload.git"
  },
  "keywords": [
    "actions",
    "node",
    "setup",
    "azure storage",
    "azure blob",
    "azure blob upload",
    "azure blob container"
  ],
  "author": "Lance McCarthy",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/LanceMcCarthy/Action-AzureBlobUpload/issues"
  },
  "homepage": "https://github.com/LanceMcCarthy/Action-AzureBlobUpload#readme",
  "devDependencies": {
    "@actions/core": "^3.0.0",
    "@azure/identity": "^4.13.0",
    "@azure/storage-blob": "^12.31.0",
    "@eslint/eslintrc": "^3.3.4",
    "@eslint/js": "9.39.3",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/mime-types": "^3.0.1",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vercel/ncc": "^0.38.4",
    "eslint": "9.39.3",
    "eslint-plugin-github": "^6.0.0",
    "eslint-plugin-i18n-text": "^1.0.1",
    "eslint-plugin-jest": "^29.15.1",
    "globals": "^17.4.0",
    "jest": "^30.2.0",
    "jest-util": "^30.2.0",
    "mime-types": "^3.0.2",
    "node-notifier": "^10.0.1",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  }
}
